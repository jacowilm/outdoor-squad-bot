# Robo-Nick — environment variables
# Copy these into the Render service's "Environment" tab. Do NOT commit real
# values. Anything marked (secret) must be entered in Render, never in git.

# ── AI provider (REQUIRED) ────────────────────────────────────────────────
# Primary is Anthropic Claude Sonnet 4.6 (the deterministic layer handles most
# questions; the AI only answers the long tail, where Sonnet's reliability and
# not-inventing-facts matter — Haiku used to hallucinate timetable slots). Get a
# key at console.anthropic.com → API keys, and SET A MONTHLY SPEND CAP.
OUTDOOR_SQUAD_ANTHROPIC_API_KEY=            # (secret) your Anthropic key
OUTDOOR_SQUAD_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional failover provider. Leave blank to run Anthropic-only (simpler/cheaper).
OUTDOOR_SQUAD_OPENAI_API_KEY=               # (secret) optional, platform.openai.com
OUTDOOR_SQUAD_OPENAI_MODEL=gpt-5-mini

# ── Mode + admin (REQUIRED) ───────────────────────────────────────────────
OUTDOOR_SQUAD_DEPLOYMENT_MODE=handoff
OUTDOOR_SQUAD_ADMIN_USERNAME=outdoorsquad
OUTDOOR_SQUAD_ADMIN_PASSWORD=               # (secret) a long random password — this guards /admin

# ── Business details (already correct — change only if they change) ───────
OUTDOOR_SQUAD_TRIAL_LINK=https://momence.com/The-Outdoor-Squad-/membership/Squad-Intro-Class/263360
OUTDOOR_SQUAD_HUMAN_EMAIL=innerwest@outdoorsquad.com.au
OUTDOOR_SQUAD_HUMAN_PHONE=0402 439 361

# ── Database (REQUIRED) — your own Supabase project ───────────────────────
# Create a project at supabase.com, run supabase_schema.sql in the SQL editor,
# then copy these from Project Settings → API.
SUPABASE_URL=                               # https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=                  # (secret) service_role key

# ── Lead notifications (needed for handoff_ready: true) ───────────────────
# Leads always appear in /admin; this is the live "ping me when a lead comes in".
# Pick ONE path. The notification send runs in a background thread, so a slow
# endpoint never delays the visitor's chat reply.
#
#  A) RECOMMENDED on Render — webhook → n8n (or Zapier/Make) for email + SMS.
#     HTTPS, so it works on Render. Point this at your n8n "Lead webhook" URL
#     (import handoff/Outdoor-Squad-n8n-workflow.json). n8n then emails + texts.
OUTDOOR_SQUAD_LEAD_SUMMARY_WEBHOOK_URL=      # https://<your-n8n>/webhook/outdoor-squad-lead
OUTDOOR_SQUAD_LEAD_SUMMARY_WEBHOOK_SECRET=   # (secret) optional; match n8n Header Auth
OUTDOOR_SQUAD_LEAD_SUMMARY_PHONE_TO=+61402439361   # passed to the webhook for SMS routing
#
#  B) Direct SMTP email. WARNING: Render BLOCKS outbound SMTP ports 25/465/587,
#     so Gmail/Outlook SMTP will silently fail (the send times out, nothing is
#     delivered, but handoff_ready still flips green). If you want direct email,
#     use a transactional provider on a NON-blocked port: Resend
#     (smtp.resend.com:2587) or SendGrid (smtp.sendgrid.net:2525), with a
#     verified sender. Gmail can't do this — its only ports are blocked.
OUTDOOR_SQUAD_LEAD_SUMMARY_EMAIL_TO=innerwest@outdoorsquad.com.au
OUTDOOR_SQUAD_SMTP_HOST=                      # e.g. smtp.resend.com (NOT smtp.gmail.com on Render)
OUTDOOR_SQUAD_SMTP_PORT=2587                  # 2587 (Resend) or 2525 (SendGrid); 587/465 are blocked on Render
OUTDOOR_SQUAD_SMTP_USER=                      # (secret) e.g. "resend"
OUTDOOR_SQUAD_SMTP_PASSWORD=                  # (secret) e.g. your Resend API key
OUTDOOR_SQUAD_SMTP_FROM=                      # a verified-sender address on that provider

# ── Abuse controls (optional — sensible defaults already apply) ───────────
OUTDOOR_SQUAD_MAX_MESSAGE_LEN=2000
OUTDOOR_SQUAD_RATE_MAX=30
OUTDOOR_SQUAD_RATE_WINDOW=60
